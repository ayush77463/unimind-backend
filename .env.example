# Optional. Required only for backend /chat and Gemini-quality embeddings.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase PostgreSQL (cloud-persistent memory) ────────────
# When set, memory persists across Render restarts/sleeps.
# Leave empty to use local SQLite + FAISS (development mode).
SUPABASE_DB_HOST=db.ppizfuwwlylahzimegfi.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_password_here

# Memory settings
SHORT_TERM_MEMORY_SIZE=20
EPISODIC_MEMORY_MAX=100
SEMANTIC_MEMORY_MAX=500
HASH_EMBEDDING_DIM=384

# Server settings
HOST=0.0.0.0
PORT=8000

# Render persistent disk (only for paid tier; free tier uses Supabase)
# RENDER_DISK_PATH=/opt/render/project/src/storage
